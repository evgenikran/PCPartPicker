<Window x:Class="PcBuilder.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PC Builder"
        Height="550"
        Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.Resources>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0 5 0 15"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0 5 0 15"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Margin="40"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="600">

            <StackPanel>

                <!-- Header -->
                <TextBlock Text="PC Builder"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0 0 0 25"
                           HorizontalAlignment="Center"/>

                <!-- Budget -->
                <TextBlock Text="Budget"
                           FontWeight="SemiBold"
                           Foreground="#555"/>

                <TextBox x:Name="BudgetTextBox"/>

                <!-- Workload -->
                <TextBlock Text="Workload"
                           FontWeight="SemiBold"
                           Foreground="#555"/>

                <ComboBox x:Name="WorkloadComboBox"/>
                    
                

                <!-- Button -->
                <Button Content="Generate Build"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0 10 0 20"
                        Click="GenerateButton_Click"/>

                <!-- Output -->
                <TextBlock Text="Build Recommendation"
                           FontWeight="SemiBold"
                           Foreground="#555"/>

                <TextBox x:Name="OutputTextBox"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Height="180"
                         Background="#FAFAFA"
                         BorderBrush="#E0E0E0"
                         TextWrapping="Wrap"
                         IsReadOnly="True"/>

            </StackPanel>

        </Border>
    </Grid>
</Window>
